---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import VersionSelector from '../../components/VersionSelector.astro';
import { t, getLocalizedPath } from '../../i18n/utils';
import { VERSIONS, getLatestVersion, getVersionFromSlug } from '../../config/versions';

const lang = 'es';
const allDocs = await getCollection('docs');
const latestVersion = getLatestVersion();

const docsByVersion = VERSIONS.map(v => ({
  version: v,
  docs: allDocs
    .filter(doc => getVersionFromSlug(doc.id) === v.id)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
}));
---

<Layout lang={lang} title={t('docsHub.title', lang)}>
  <Navbar lang={lang} />
  <main class="docs-hub">
    <div class="hub-header">
      <h1 class="hub-title">{t('docsHub.title', lang)}</h1>
      <p class="hub-subtitle">{t('docsHub.subtitle', lang)}</p>

      <div class="hub-controls">
        <div class="search-wrapper">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="M21 21l-4.35-4.35"></path>
          </svg>
          <input
            type="search"
            class="search-input"
            placeholder={t('docsHub.searchPlaceholder', lang)}
            id="docs-search"
          />
        </div>
        <VersionSelector
          lang={lang}
          currentVersion={latestVersion.id}
          versions={VERSIONS}
        />
      </div>
    </div>

    {docsByVersion.map(({ version, docs }) => (
      <div
        class="docs-grid"
        data-version={version.id}
        style={version.id !== latestVersion.id ? 'display:none' : ''}
      >
        {docs.map(doc => (
          <a
            href={`${import.meta.env.BASE_URL}docs/${doc.id}/`}
            class="doc-card"
            data-title={doc.data.title?.toLowerCase() ?? ''}
            data-description={doc.data.description?.toLowerCase() ?? ''}
          >
            {doc.data.icon && (
              <div class="card-icon-wrap">
                <svg class="card-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d={doc.data.icon} />
                </svg>
              </div>
            )}
            <h3 class="card-title">{doc.data.title}</h3>
            <p class="card-description">{doc.data.description}</p>
          </a>
        ))}
      </div>
    ))}
  </main>
  <Footer lang={lang} />
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const search = document.getElementById('docs-search') as HTMLInputElement;
    if (!search) return;
    search.addEventListener('input', () => {
      const query = search.value.toLowerCase().trim();
      document.querySelectorAll('.doc-card').forEach(card => {
        const el = card as HTMLElement;
        const parent = el.closest('[data-version]') as HTMLElement;
        if (parent && parent.style.display === 'none') return;
        const title = el.getAttribute('data-title') ?? '';
        const desc = el.getAttribute('data-description') ?? '';
        el.style.display = (title.includes(query) || desc.includes(query)) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .docs-hub {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
    flex-grow: 1;
  }
  .hub-header {
    margin-bottom: 3rem;
  }
  .hub-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.75rem;
    text-transform: uppercase;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }
  .hub-subtitle {
    font-family: var(--font-body);
    color: var(--color-ink-light);
    font-size: 1rem;
    margin-bottom: 2rem;
  }
  .hub-controls {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .search-wrapper {
    position: relative;
    flex: 1;
  }
  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-ink-light);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.625rem 1rem 0.625rem 2.5rem;
    border: var(--border-width) solid var(--color-ink);
    border-radius: var(--border-radius);
    background: var(--color-surface);
    color: var(--color-ink);
  }
  .search-input::placeholder {
    color: var(--color-ink-light);
    opacity: 0.6;
  }
  .search-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .docs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .doc-card {
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-ink);
    box-shadow: var(--shadow-brutal);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: all 0.1s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .doc-card:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-brutal-hover);
  }
  .doc-card:active {
    transform: translate(4px, 4px);
    box-shadow: var(--shadow-brutal-none);
  }
  .card-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper);
    border: 1px solid var(--color-lines);
    color: var(--color-accent);
  }
  .card-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-ink);
  }
  .card-description {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-ink-light);
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .docs-hub {
      padding: 3rem 1.5rem 5rem;
    }
    .hub-title {
      font-size: 2.5rem;
    }
    .hub-subtitle {
      font-size: 1.125rem;
    }
    .hub-controls {
      flex-direction: row;
      align-items: stretch;
    }
    .docs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .docs-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
