---
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/utils';
import CodeBlock from '../ui/CodeBlock.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const precommitCode = `repos:
  - repo: https://github.com/Diego303/vigil-cli
    rev: v1.0.0
    hooks:
      - id: vigil
        args: [scan, --changed-only]`;

const cicdCode = `- name: Scan AI Code
  run: vigil scan src/ \\
       --format sarif \\
       --output report.sarif
- uses: github/codeql-action/upload-sarif
  with:
    sarif_file: report.sarif`;

const architectCode = `# En tu .architect.yaml
guardrails:
  quality_gates:
    - name: vigil
      command: "vigil scan src/"
      required: true`;
---

<section class="integration-section">
  <div class="integration-inner">
    <div class="integration-header">
      <h2 class="integration-title">{t('integration.title', lang)}</h2>
      <p class="integration-subtitle">{t('integration.subtitle', lang)}</p>
    </div>

    <div class="integration-grid">
      <CodeBlock title={t('integration.precommit', lang)} code={precommitCode} />
      <CodeBlock title={t('integration.cicd', lang)} code={cicdCode} />
      <CodeBlock title={t('integration.architect', lang)} code={architectCode} dark titleHref="https://diego303.github.io/architect-docs/" />
    </div>
  </div>
</section>

<style>
  .integration-section {
    padding: 5rem 0;
    border-top: var(--border-width) solid var(--color-ink);
    background: var(--color-surface);
  }
  .integration-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .integration-header {
    text-align: center;
    max-width: 48rem;
    margin: 0 auto 3rem;
  }
  .integration-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 2rem;
    text-transform: uppercase;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-bottom: 1rem;
  }
  .integration-subtitle {
    font-family: var(--font-body);
    color: var(--color-ink-light);
    line-height: 1.5;
  }
  .integration-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .integration-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
