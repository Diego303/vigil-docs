---
import type { Lang } from '../../i18n/ui';
import { t, getLocalizedPath } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const lines = t('hero.terminalLines', lang) as Array<{ type: string; text: string }>;
---

<section class="hero">
  <div class="hero-inner">
    <!-- Left Column: Text -->
    <div class="hero-text crop-mark crop-tl crop-bl">
      <div class="accent-bar"></div>
      <div class="hero-content">
        <div class="status-badge">{t('hero.status', lang)}</div>

        <h1 class="hero-title">
          {t('hero.titleLine1', lang)} <span class="highlight">{t('hero.titleHighlight', lang)}</span>
          <br />{t('hero.titleLine2', lang)}
        </h1>

        <p class="hero-description">{t('hero.description', lang)}</p>

        <div class="hero-actions">
          <div class="install-block">
            <span class="install-prompt">$</span>
            <code class="install-cmd" id="install-cmd">{t('hero.installCmd', lang)}</code>
            <button class="copy-btn" title="Copy" aria-label="Copy install command">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="0" ry="0"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
          <a href="https://github.com/Diego303/vigil-cli" target="_blank" rel="noopener" class="tech-btn demo-btn">
            {t('hero.githubBtn', lang)}
          </a>
        </div>

        <div class="hero-tagline">
          <span class="tagline-check">&check;</span> {t('hero.tagline', lang)}
        </div>
      </div>
    </div>

    <!-- Right Column: Terminal -->
    <div class="hero-terminal crop-mark crop-tr crop-br">
      <div class="terminal-header">
        <span class="terminal-title">{t('hero.terminalTitle', lang)}</span>
        <div class="terminal-dots">
          <span class="tdot"></span>
          <span class="tdot"></span>
          <span class="tdot tdot--accent"></span>
        </div>
      </div>
      <div class="terminal-body no-scrollbar">
        {lines.map(line => {
          if (line.type === 'prompt') return <p class="line"><span class="prompt-user">user@host:~$</span> {line.text}</p>;
          if (line.type === 'critical') return <p class="line line--critical">{line.text}</p>;
          if (line.type === 'alert') return <p class="line line--alert">{line.text}</p>;
          if (line.type === 'fail') return <p class="line line--fail">{line.text}</p>;
          if (line.type === 'detail') return <p class="line line--detail">{line.text}</p>;
          if (line.type === 'separator') return <p class="line line--info">{line.text}</p>;
          return <p class="line line--info">{line.text}</p>;
        })}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.querySelector('.copy-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const cmd = document.getElementById('install-cmd')?.textContent ?? '';
      navigator.clipboard.writeText(cmd).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<span style="font-size:0.75rem;font-weight:700;padding:0 0.25rem">OK</span>';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = original;
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  });
</script>

<style>
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  /* Left column */
  .hero-text {
    width: 100%;
    position: relative;
    padding-left: 1.5rem;
  }
  .accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: var(--color-accent);
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .status-badge {
    display: inline-block;
    align-self: flex-start;
    background: var(--color-ink);
    color: var(--color-surface);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.1;
    color: var(--color-ink);
    overflow-wrap: break-word;
  }
  .highlight {
    color: var(--color-accent);
    background: var(--color-ink);
    padding: 0 0.5rem;
    white-space: nowrap;
  }
  .hero-description {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-ink-light);
    max-width: 36rem;
    line-height: 1.6;
  }
  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .install-block {
    display: flex;
    align-items: center;
    border: var(--border-width) solid var(--color-ink);
    background: var(--color-surface);
    box-shadow: var(--shadow-brutal);
    max-width: 100%;
  }
  .install-prompt {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    color: var(--color-ink-light);
    background: var(--color-paper);
    border-right: var(--border-width) solid var(--color-ink);
    flex-shrink: 0;
  }
  .install-cmd {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    flex: 1;
    color: var(--color-ink);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .copy-btn {
    padding: 0.75rem;
    border: none;
    border-left: var(--border-width) solid var(--color-ink);
    background: var(--color-surface);
    cursor: pointer;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    color: var(--color-ink);
  }
  .copy-btn:hover, .copy-btn.copied {
    background: var(--color-accent);
    color: var(--color-surface);
  }
  .demo-btn {
    background: var(--color-ink);
    color: var(--color-surface);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    padding: 0.75rem 2rem;
    text-decoration: none;
    text-align: center;
  }
  .hero-tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-light);
  }
  .tagline-check {
    color: var(--color-accent);
  }

  /* Right column: Terminal */
  .hero-terminal {
    width: 100%;
    border: var(--border-width) solid var(--color-ink);
    box-shadow: var(--shadow-brutal);
    background: var(--color-surface);
    padding: 1.5rem;
  }
  .terminal-header {
    border-bottom: var(--border-width) solid var(--color-ink);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink);
  }
  .terminal-dots {
    display: flex;
    gap: 0.5rem;
  }
  .tdot {
    width: 0.75rem;
    height: 0.75rem;
    background: var(--color-ink);
  }
  .tdot--accent {
    background: var(--color-accent);
  }
  .terminal-body {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.6;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .line { margin: 0; }
  .line + .line { margin-top: 0.125rem; }
  .line--critical, .line--alert {
    color: var(--color-alert);
    font-weight: 700;
    margin-top: 0.75rem;
  }
  .line--fail {
    color: var(--color-alert);
    font-weight: 700;
    margin-top: 0.75rem;
  }
  .line--detail {
    color: var(--color-ink-light);
    padding-left: 1rem;
  }
  .line--info {
    color: var(--color-ink);
  }
  .prompt-user {
    color: var(--color-accent);
  }

  @media (min-width: 480px) {
    .hero-title {
      font-size: 2.75rem;
    }
    .terminal-body {
      font-size: 0.8125rem;
    }
  }

  @media (min-width: 640px) {
    .hero-actions {
      flex-direction: row;
      align-items: stretch;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 8rem 2rem;
    }
    .hero-inner {
      flex-direction: row;
    }
    .hero-text, .hero-terminal {
      width: 50%;
    }
    .hero-title {
      font-size: 3.75rem;
    }
    .hero-description {
      font-size: 1.25rem;
    }
  }
</style>
