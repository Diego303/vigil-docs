---
interface Props {
  stat: string;
  title: string;
  description: string;
}

const { stat, title, description } = Astro.props;
---

<div class="stat-card">
  <div class="stat-number">{stat}</div>
  <h3 class="stat-title">{title}</h3>
  <p class="stat-description">{description}</p>
</div>

<style>
  .stat-card {
    border: var(--border-width) solid var(--color-surface);
    padding: 1.5rem;
    box-shadow: var(--shadow-brutal-white);
    background: var(--color-ink);
    transition: transform 0.15s;
  }
  .stat-card:hover {
    transform: translateY(-4px);
  }
  .stat-number {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 3rem;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .stat-title {
    font-family: var(--font-mono);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-surface);
    color: var(--color-surface);
  }
  .stat-description {
    font-family: var(--font-body);
    font-size: 0.875rem;
    opacity: 0.9;
    line-height: 1.5;
    color: var(--color-surface);
  }
</style>
