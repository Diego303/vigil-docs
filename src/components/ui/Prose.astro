---
---

<div class="prose">
  <slot />
</div>

<style>
  .prose {
    font-family: var(--font-body);
    color: var(--color-ink);
    line-height: 1.75;
    max-width: 75ch;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin-top: 2em;
    margin-bottom: 0.75em;
  }

  .prose :global(h1) { font-size: 2.25rem; margin-top: 0; }
  .prose :global(h2) {
    font-size: 1.5rem;
    border-bottom: var(--border-width) solid var(--color-lines);
    padding-bottom: 0.5em;
  }
  .prose :global(h3) { font-size: 1.25rem; }
  .prose :global(h4) { font-size: 1.125rem; }

  .prose :global(p) {
    margin-bottom: 1.25em;
    color: var(--color-ink-light);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
  }
  .prose :global(a:hover) {
    color: var(--color-ink);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-paper);
    border: 1px solid var(--color-lines);
    padding: 0.125em 0.375em;
  }

  .prose :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-ink);
    box-shadow: var(--shadow-brutal);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5em 0;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 1.25em;
    color: var(--color-ink-light);
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
  }

  .prose :global(ul li::marker) {
    content: '\25C7  ';
    color: var(--color-accent);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1em;
    margin: 1.5em 0;
    color: var(--color-ink-light);
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    text-align: left;
    padding: 0.75em;
    border: var(--border-width) solid var(--color-ink);
    background: var(--color-paper);
    white-space: nowrap;
  }

  .prose :global(td) {
    padding: 0.75em;
    border: 1px solid var(--color-lines);
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .prose :global(h1) { font-size: 1.75rem; }
    .prose :global(h2) { font-size: 1.25rem; }
    .prose :global(h3) { font-size: 1.125rem; }

    .prose :global(pre) {
      font-size: 0.8125rem;
      padding: 1rem;
      box-shadow: 2px 2px 0px 0px var(--color-ink);
    }

    .prose :global(th),
    .prose :global(td) {
      padding: 0.5em;
      font-size: 0.8125rem;
    }
  }

  .prose :global(hr) {
    border: none;
    border-top: var(--border-width) solid var(--color-lines);
    margin: 2em 0;
  }

  .prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
</style>
